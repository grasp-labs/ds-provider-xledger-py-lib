{
  "name": "companies",
  "type": "read",
  "description": "Xledger companies dataset.",
  "pattern": "direct",
  "incremental": {
    "kind": "time_field",
    "field": "modifiedAt",
    "filter_field": "modifiedAt_gte"
  },
  "pagination": {
    "kind": "cursor",
    "first": 1000
  },
  "fields": [
    {
      "name": "dbId",
      "type": "int64",
      "description": "The unique identifier for the company.",
      "default": true
    },
    {
      "name": "code",
      "type": "string",
      "description": "The code of the company.",
      "default": true
    },
    {
      "name": "description",
      "type": "string",
      "description": "The description of the company.",
      "default": true
    },
    {
      "name": "modifiedAt",
      "type": "string",
      "description": "The incremental watermark field for the companies dataset.",
      "default": true
    },
    {
      "name": "companyNumber",
      "type": "string",
      "description": "The organisation number of the company.",
      "default": true
    },
    {
      "name": "ownerDbId",
      "type": "int64",
      "description": "The unique identifier for owner.",
      "default": false
    },
    {
      "name": "taxNumber",
      "type": "string",
      "description": "The tax number of the company.",
      "default": true
    }
  ]
}
